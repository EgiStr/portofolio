# Ecosystem Environment Variables

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# NextAuth (Manager CMS)
NEXTAUTH_URL="http://localhost:3002"
# Generate a new secret with: openssl rand -base64 32
NEXTAUTH_SECRET="MWZlNDg5YWU4ZTY0MjBhYjc5ODFjMzZhNTQ3YmI1Y2U="

# OAuth Providers (Optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------------------------------------------------------------------------
# Centralized Site Settings - cross-app cache invalidation (bd-02)
# ---------------------------------------------------------------------------
# Shared secret used by `apps/manager/src/lib/revalidate-fanout.ts` to call
# the `/api/revalidate` endpoints on each consumer app. Set the SAME value
# in all 5 apps. Generate with: openssl rand -hex 32
REVALIDATE_SECRET=""

# Public URLs of each consumer app. The manager app uses these to fan out
# invalidations; the consumer apps do not read them but Vercel may inject
# `NEXT_PUBLIC_*` for client bundles. Use the deployed domains in prod
# and `http://localhost:<port>` locally.
NEXT_PUBLIC_LANDING_URL="http://localhost:3000"
NEXT_PUBLIC_BLOG_URL="http://localhost:3001"
NEXT_PUBLIC_EDS_URL="http://localhost:3003"
NEXT_PUBLIC_HUB_URL="http://localhost:3003"

# ---------------------------------------------------------------------------
# Email (Resend) - contact form + newsletter
# ---------------------------------------------------------------------------
# Sign up at https://resend.com and generate an API key.
# If unset, emails are logged to the server console instead of being sent.
# Generate with: openssl rand -hex 16  (used in the From: address)
RESEND_API_KEY=""
CONTACT_EMAIL_FROM="Eggi Satria <noreply@eggisatria.dev>"
# Optional: override where contact-form notifications are delivered.
# Defaults to the `email` site-config value.
CONTACT_NOTIFY_TO=""
# Optional: base URL used in newsletter unsubscribe links.
# Defaults to https://eggisatria.dev.
NEXT_PUBLIC_SITE_URL=""

# ---------------------------------------------------------------------------
# Newsletter unsubscribe token signing
# ---------------------------------------------------------------------------
# HMAC secret used to sign one-click unsubscribe links. Rotate to invalidate
# outstanding links. Falls back to NEXTAUTH_SECRET, then a dev-only fallback.
# Generate with: openssl rand -hex 32
NEWSLETTER_SECRET=""